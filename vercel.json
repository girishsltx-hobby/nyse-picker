{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm run build"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "installCommand": "pip install -r requirements.txt"
    }
  }
}