{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm run build"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "framework": "python",
      "entrypoint": "main.py"
    }
  },
  "crons": [
    {
      "path": "/_/backend/api/cron/fetch-data",
      "schedule": "*/5 * * * *"
    }
  ]
}